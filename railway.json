{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "server/Dockerfile",
    "watchPatterns": ["server/**"]
  },
  "deploy": {
    "startCommand": "uvicorn app:app --host 0.0.0.0 --port 8000",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
